{
  "name": "textric",
  "version": "2.0.0",
  "sideEffects": false,
  "description": "Text layout for AI. Line wrapping, rich text, and precise metrics — pure JS, no browser.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./wrap": {
      "types": "./dist/wrap.d.ts",
      "import": "./dist/wrap.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench",
    "bench:report": "tsx benchmarks/generate-report.ts",
    "lint": "oxlint src",
    "test:golden": "tsx test/helpers/generate-golden-values.ts | diff - test/fixtures/golden-values.json",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "text",
    "layout",
    "font",
    "metrics",
    "typography",
    "wrapping",
    "line-break",
    "rich-text",
    "opentype",
    "no-native-deps",
    "server-side",
    "ai",
    "pure-js"
  ],
  "author": "ShiyuCheng2018",
  "license": "MIT",
  "homepage": "https://textric-web-production.up.railway.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShiyuCheng2018/textric.git"
  },
  "bugs": {
    "url": "https://github.com/ShiyuCheng2018/textric/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "opentype.js": "^1.3.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/opentype.js": "^1.3.9",
    "@vitest/coverage-v8": "^3.0.0",
    "oxlint": "^1.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
